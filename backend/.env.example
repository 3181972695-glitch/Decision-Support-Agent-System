# ── Application ──────────────────────────────────────────────────
DEBUG=true

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Demo Mode ────────────────────────────────────────────────────
DEMO_MODE=false

# ── LLM Provider (any OpenAI-compatible API) ─────────────────────
LLM_PROVIDER=deepseek
LLM_BASE_URL=http://localhost:4000/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=coder
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ── Per-role model routing (optional, falls back to LLM_MODEL) ──
# MODERATOR_MODEL=fast
# ARGUMENT_MODEL=coder
# JUDGE_MODEL=fast

# ── Per-role token limits (optional) ─────────────────────────────
# MODERATOR_MAX_TOKENS=1024
# OPENING_MAX_TOKENS=2048
# REBUTTAL_MAX_TOKENS=1536
# CROSS_EXAM_MAX_TOKENS=512
# JUDGE_MAX_TOKENS=16384

# ── Context window ───────────────────────────────────────────────
# CONTEXT_MAX_CHARS=1500

# ── Debate ───────────────────────────────────────────────────────
DEBATE_MAX_ROUNDS=3

# ── Database ─────────────────────────────────────────────────────
DB_BACKEND=memory
# DATABASE_URL=sqlite+aiosqlite:///debates.db
